# Force LF line endings for shell scripts and other files that run on Linux.
# Without this, Windows clones can introduce CRLF which crashes scripts on the Pi
# (bash will report `$'\r': command not found`).
*.sh         text eol=lf
*.bash       text eol=lf
*.service    text eol=lf
*.conf       text eol=lf
chromium-autostart.sh text eol=lf
